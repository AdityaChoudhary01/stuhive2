{
    "name": "stuhive-next",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint .",
        "build:cloudflare": "opennextjs-cloudflare build",
        "deploy:cloudflare": "opennextjs-cloudflare deploy",
        "db:generate": "drizzle-kit generate",
        "db:migrate:local": "wrangler d1 migrations apply stuhive --local",
        "db:migrate:remote": "wrangler d1 migrations apply stuhive --remote",
        "db:import:local": "wrangler d1 execute stuhive --file migration-output/mongodb-to-d1.sql --local",
        "db:import:remote": "wrangler d1 execute stuhive --file migration-output/mongodb-to-d1.sql --remote",
        "db:sync:local": "npm run db:migrate:local && npm run db:import:local",
        "db:sync:remote": "npm run db:migrate:remote && npm run db:import:remote"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.993.0",
        "@aws-sdk/s3-request-presigner": "^3.993.0",
        "@google/generative-ai": "^0.24.1",
        "@hookform/resolvers": "^3.3.2",
        "@radix-ui/react-alert-dialog": "^1.1.15",
        "@radix-ui/react-avatar": "^1.1.11",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-scroll-area": "^1.2.10",
        "@radix-ui/react-separator": "^1.1.8",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-toast": "^1.2.15",
        "ably": "^2.17.1",
        "axios": "^1.6.2",
        "bcrypt-ts": "^8.0.1",
        "canvas-confetti": "^1.9.4",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^2.30.0",
        "drizzle-orm": "^0.30.10",
        "google-auth-library": "^10.5.0",
        "lucide-react": "^0.577.0",
        "next": "^15.0.0",
        "next-auth": "^5.0.0-beta.30",
        "pdf-lib": "^1.17.1",
        "pdfjs-dist": "^3.11.174",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-hook-form": "^7.48.2",
        "react-icons": "^5.5.0",
        "react-markdown": "^10.1.0",
        "react-pdf": "^8.0.2",
        "react-syntax-highlighter": "^16.1.0",
        "recharts": "^3.7.0",
        "remark-gfm": "^4.0.1",
        "tailwind-merge": "^2.6.1",
        "tailwindcss-animate": "^1.0.7",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@cloudflare/next-on-pages": "^1.13.16",
        "@opennextjs/cloudflare": "^1.17.1",
        "autoprefixer": "^10.0.1",
        "drizzle-kit": "^0.21.4",
        "eslint": "^8.0.0",
        "eslint-config-next": "15.0.0",
        "postcss": "^8",
        "tailwindcss": "^3.3.0",
        "wrangler": "^4.65.0"
    }
}
